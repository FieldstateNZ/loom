  "query": "\n            SELECT role, content, usage, raw_provider_payload\n            FROM messages\n            WHERE conversation_id = $1\n              AND EXISTS (\n                  SELECT 1 FROM conversations c\n                  WHERE c.id = $1 AND c.tenant_id = $2\n              )\n            ORDER BY seq\n            LIMIT $3 OFFSET $4\n            ",
