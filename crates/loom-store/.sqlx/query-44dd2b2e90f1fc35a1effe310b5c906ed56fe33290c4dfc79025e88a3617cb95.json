  "query": "\n            SELECT\n                id, tenant_id, virtual_key_id, provider, status, provider_batch_id,\n                results_url, total_items, processing_count, succeeded_count,\n                errored_count, canceled_count, expired_count, error,\n                created_at, updated_at, ended_at\n            FROM batch_jobs\n            WHERE status <> 'ended'\n            ORDER BY created_at\n            LIMIT $1\n            ",
