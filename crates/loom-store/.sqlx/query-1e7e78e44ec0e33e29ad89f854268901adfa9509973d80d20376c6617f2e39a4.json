{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT e.seq, e.kind, e.at\n            FROM session_events e\n            JOIN sessions s ON s.id = e.session_id\n            WHERE e.session_id = $1 AND s.tenant_id = $2 AND e.seq > $3\n            ORDER BY e.seq\n            LIMIT $4\n            ",
